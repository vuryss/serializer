{
    "name": "vuryss/serializer",
    "description": "A fast, extensible PHP data structures serializer & deserializer",
    "type": "library",
    "license": "MIT",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "phpdocumentor/reflection-docblock": "^6.0",
        "phpstan/phpdoc-parser": "^2.3",
        "psr/cache": "^3.0",
        "symfony/property-info": "^7.4.1 || ^8.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.3",
        "pestphp/pest-plugin-faker": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.92",
        "mockery/mockery": "^1.6.12",
        "symfony/serializer": "^7.4.2 || ^8.0",
        "phpstan/phpstan": "^2.1.33",
        "captainhook/captainhook-phar": "^5.27.3",
        "captainhook/hook-installer": "^1.0.4",
        "ramsey/conventional-commits": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Vuryss\\Serializer\\": "src/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.4 || ^8.0"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vuryss\\Serializer\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "captainhook/captainhook-phar": true,
            "captainhook/hook-installer": true
        }
    },
    "scripts": {
        "test": "pest --no-coverage",
        "coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage-html coverage",
        "check-cs": "PHP_CS_FIXER_IGNORE_ENV=1 vendor/bin/php-cs-fixer fix --diff --dry-run --using-cache=no",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G -v",
        "qa": [
            "@check-cs",
            "@analyse",
            "@test"
        ],
        "deps:lowest": "@composer update --prefer-lowest --prefer-stable --with-all-dependencies",
        "deps:highest": "@composer update --prefer-stable --with-all-dependencies"
    }
}
